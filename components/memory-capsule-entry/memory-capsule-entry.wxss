.capsule-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.entry-title {
  color: #2b2024;
  font-size: 32rpx;
  font-weight: 700;
}

.entry-desc {
  margin-top: 10rpx;
  color: #9a7b84;
  font-size: 26rpx;
  line-height: 1.5;
}

.entry-action {
  flex: 0 0 auto;
  padding: 10rpx 20rpx;
  border: 1rpx solid #e6cbd0;
  border-radius: 10rpx;
  color: #9f5d6c;
  font-size: 25rpx;
  background: #fff9f8;
}

.entry-action::before {
  content: '';
  display: inline-block;
  width: 11rpx;
  height: 11rpx;
  margin-right: 9rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  border-radius: 2rpx;
  transform: rotate(45deg);
}
