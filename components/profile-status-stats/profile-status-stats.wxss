.card-title {
  color: #2b2024;
  font-size: 32rpx;
  font-weight: 700;
}

.stats-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-item {
  flex: 1;
  min-width: 0;
  padding: 22rpx 16rpx;
  border-radius: 20rpx;
  background: #fff8f6;
}

.stat-value {
  color: #e85d75;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.stat-title {
  margin-top: 12rpx;
  color: #4f3c43;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.35;
}

.stat-desc {
  margin-top: 8rpx;
  color: #9a7b84;
  font-size: 22rpx;
  line-height: 1.35;
}
