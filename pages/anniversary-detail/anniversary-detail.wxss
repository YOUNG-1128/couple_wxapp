page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff8f6;
}

.detail-scroll {
  flex: 1;
  overflow-y: hidden;
}

.detail-page {
  padding: 32rpx;
}

.hero-card {
  position: relative;
  height: 840rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f7e7c8;
  box-shadow: 0 14rpx 28rpx rgba(97, 73, 46, 0.18);
}

.hero-cover,
.hero-placeholder {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-placeholder {
  background: linear-gradient(160deg, #f3dbb6 0%, #dec29f 100%);
}

.hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.26) 0%, rgba(0, 0, 0, 0.3) 55%, rgba(0, 0, 0, 0.36) 100%);
}

.hero-top-title {
  position: absolute;
  top: 44rpx;
  left: 0;
  right: 0;
  text-align: center;
  color: rgba(255, 255, 255, 0.95);
  font-size: 46rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-count-label {
  position: absolute;
  top: 152rpx;
  left: 0;
  right: 0;
  text-align: center;
  color: rgba(255, 255, 255, 0.92);
  font-size: 56rpx;
  font-weight: 600;
}

.hero-count-number {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 164rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.96);
  font-size: 230rpx;
  font-weight: 500;
  line-height: 1;
  letter-spacing: 4rpx;
  font-family: 'Times New Roman', serif;
}

.hero-start-date {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 44rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.94);
  font-size: 44rpx;
  font-weight: 500;
}

.detail-title {
  margin-top: 2rpx;
  color: #2b2024;
  font-size: 40rpx;
  font-weight: 700;
}

.detail-countdown {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #b06d7a;
  font-size: 23rpx;
  background: #ffeef2;
}

.detail-meta {
  margin-top: 10rpx;
  color: #8b6f79;
  font-size: 24rpx;
}

.detail-note {
  margin-top: 12rpx;
  color: #60484f;
  font-size: 25rpx;
  line-height: 1.7;
}

.memory-title {
  color: #2b2024;
  font-size: 30rpx;
  font-weight: 700;
}

.memory-placeholder {
  margin-top: 10rpx;
  color: #8f727b;
  font-size: 24rpx;
  line-height: 1.6;
}
