page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fffaf8;
}

.drafts-scroll {
  flex: 1;
  overflow-y: hidden;
}

.drafts-page {
  padding: 32rpx;
}

.entry-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.entry-title {
  color: #2b2024;
  font-size: 30rpx;
  font-weight: 700;
}

.entry-action {
  color: #d86f83;
  font-size: 25rpx;
}

.empty-box {
  margin-top: 24rpx;
  padding: 34rpx 28rpx;
  border-radius: 20rpx;
  color: #9b7f87;
  font-size: 26rpx;
  text-align: center;
  background: #fff1f4;
}

.draft-title {
  display: -webkit-box;
  overflow: hidden;
  color: #4f3c43;
  font-size: 26rpx;
  line-height: 1.5;
  text-overflow: ellipsis;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.draft-meta {
  margin-top: 10rpx;
  color: #9a7b84;
  font-size: 23rpx;
}

.draft-action-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.delete-btn,
.edit-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 150rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.delete-btn {
  color: #8d6d77;
  background: #f2e4e8;
}

.edit-btn {
  color: #ffffff;
  background: #d86f83;
}

.delete-btn::after,
.edit-btn::after {
  border: 0;
}
