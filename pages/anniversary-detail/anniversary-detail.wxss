page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fffaf8;
}

.detail-scroll {
  flex: 1;
  overflow-y: hidden;
}

.detail-page {
  padding: 32rpx;
}

.hero-card {
  position: relative;
  height: 600rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f7e7c8;
  box-shadow: 0 14rpx 28rpx rgba(97, 73, 46, 0.18);
}

.hero-cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(38, 28, 32, 0.04) 0%, rgba(38, 28, 32, 0.14) 100%);
}

.background-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 2;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.38);
  border-radius: 999rpx;
  color: #fff;
  font-size: 22rpx;
  background: rgba(48, 34, 39, 0.28);
  backdrop-filter: blur(12rpx);
}

.hero-content {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 88rpx 42rpx 42rpx;
  box-sizing: border-box;
}

.hero-glass-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 370rpx;
  padding: 34rpx 28rpx 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 32rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18),
    0 10rpx 28rpx rgba(35, 24, 29, 0.08);
  box-sizing: border-box;
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
}

.hero-top-title {
  color: rgba(255, 255, 255, 0.96);
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-align: center;
}

.hero-count-label {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
}

.hero-count-row {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin: 6rpx 0 12rpx;
}

.hero-count-number {
  color: #fff;
  font-size: 150rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: -6rpx;
  text-shadow: 0 4rpx 14rpx rgba(35, 24, 29, 0.18);
}

.hero-count-unit {
  margin: 0 0 18rpx 12rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 27rpx;
  font-weight: 600;
}

.hero-start-date {
  max-width: 100%;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
  line-height: 1.5;
  text-align: center;
}

.detail-time-summary {
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid rgba(216, 111, 131, 0.14);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.76);
}

.detail-time-primary {
  color: #6f505a;
  font-size: 24rpx;
  font-weight: 600;
}

.detail-time-secondary {
  margin-top: 5rpx;
  color: #a17e88;
  font-size: 21rpx;
}

.background-panel {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(88, 60, 70, 0.08);
}

.background-panel-head,
.background-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.background-panel-title {
  color: #3f2d34;
  font-size: 27rpx;
  font-weight: 700;
}

.background-panel-status {
  color: #a17e88;
  font-size: 21rpx;
}

.background-options {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.background-swatch {
  width: 54rpx;
  height: 54rpx;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-shadow: 0 0 0 2rpx rgba(141, 109, 119, 0.14);
  box-sizing: border-box;
}

.background-swatch-active {
  box-shadow: 0 0 0 3rpx #c98294;
}

.background-actions {
  justify-content: flex-start;
  margin-top: 18rpx;
}

.background-action {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 22rpx;
  background: #d86f83;
}

.background-action-muted {
  color: #9a7480;
  background: #fff0f3;
}

.memory-title {
  color: #2b2024;
  font-size: 30rpx;
  font-weight: 700;
}

.memory-placeholder {
  margin-top: 10rpx;
  color: #8f727b;
  font-size: 24rpx;
  line-height: 1.6;
}

.timeline {
  margin-top: 18rpx;
}

.timeline-year {
  position: relative;
  padding-left: 42rpx;
}

.timeline-year::before {
  position: absolute;
  top: 46rpx;
  bottom: 0;
  left: 13rpx;
  width: 2rpx;
  background: #f0d8df;
  content: '';
}

.timeline-year-label {
  margin: 18rpx 0 10rpx;
  color: #b06d7a;
  font-size: 26rpx;
  font-weight: 700;
}

.timeline-item {
  position: relative;
  margin-bottom: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #fff6f8;
}

.timeline-dot {
  position: absolute;
  top: 25rpx;
  left: -36rpx;
  width: 14rpx;
  height: 14rpx;
  border: 5rpx solid #fff;
  border-radius: 50%;
  background: #d86f83;
  box-shadow: 0 0 0 2rpx #f0d8df;
}

.timeline-meta {
  color: #a17e88;
  font-size: 21rpx;
}

.timeline-title {
  margin-top: 6rpx;
  color: #4a353c;
  font-size: 25rpx;
  line-height: 1.55;
}

.timeline-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.timeline-image {
  width: 126rpx;
  height: 126rpx;
  border-radius: 12rpx;
}

.manage-actions {
  display: flex;
  justify-content: center;
  gap: 34rpx;
  padding: 10rpx 0 26rpx;
}

.manage-action {
  color: #9a7480;
  font-size: 22rpx;
}

.manage-action-danger {
  color: #c56c78;
}
