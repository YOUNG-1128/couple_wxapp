page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fffaf8;
}

.ann-scroll {
  flex: 1;
  overflow-y: hidden;
}

.ann-page {
  padding: 32rpx;
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.page-title {
  color: #2b2024;
  font-size: 40rpx;
  font-weight: 700;
}

.new-icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  color: #b06779;
  font-size: 36rpx;
  line-height: 1;
  background: #fff1f4;
}

.hero-card {
  margin-top: 16rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background-color: #f8dde5;
}

.hero-label {
  color: #b18592;
  font-size: 22rpx;
}

.hero-main-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 8rpx;
}

.hero-title {
  color: #3f2d34;
  font-size: 34rpx;
  font-weight: 700;
}

.hero-countdown {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 23rpx;
  background: #e88aa0;
}

.hero-date {
  margin-top: 10rpx;
  color: #7f626c;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-note {
  margin-top: 8rpx;
  color: #9e8089;
  font-size: 23rpx;
}

.empty-box {
  margin-top: 22rpx;
  padding: 34rpx 28rpx;
  border-radius: 20rpx;
  color: #9b7f87;
  font-size: 25rpx;
  text-align: center;
  background: #fff1f4;
}

.ann-item {
  margin-top: 12rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #fff;
}

.ann-section {
  margin-top: 28rpx;
}

.ann-section-title {
  margin-bottom: 4rpx;
  color: #755a63;
  font-size: 25rpx;
  font-weight: 700;
}

.ann-item-past {
  opacity: 0.82;
}

.ann-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.ann-title {
  color: #2b2024;
  font-size: 30rpx;
  font-weight: 700;
}

.ann-countdown {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  background: #dd8ea1;
}

.ann-countdown-past {
  color: #8e737c;
  background: rgba(255, 255, 255, 0.72);
}

.ann-meta {
  margin-top: 8rpx;
  color: #927680;
  font-size: 23rpx;
}

.ann-elapsed {
  margin-top: 8rpx;
  color: #745963;
  font-size: 23rpx;
}

.ann-occurrence {
  margin-top: 8rpx;
  color: #a36e7b;
  font-size: 22rpx;
}

.creator-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(43, 32, 36, 0.34);
}

.creator-panel {
  width: 100%;
  padding: 30rpx 30rpx 42rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #fff;
}

.panel-title {
  color: #2b2024;
  font-size: 34rpx;
  font-weight: 700;
}

.form-input {
  width: 100%;
  border-radius: 16rpx;
  color: #2b2024;
  font-size: 26rpx;
  background: #fff5f8;
  box-sizing: border-box;
}

.form-input {
  height: 76rpx;
  margin-top: 8rpx;
  padding: 0 18rpx;
  line-height: normal;
}

.form-row {
  margin-top: 14rpx;
}

.form-row-first {
  margin-top: 18rpx;
}

.occasion-templates {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.occasion-template {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #9a7a84;
  font-size: 21rpx;
  background: #fff0f3;
}

.occasion-template-active {
  color: #fff;
  background: #c98294;
}

.form-label {
  color: #8d6d77;
  font-size: 23rpx;
}

.picker-view {
  margin-top: 8rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  color: #5b444c;
  font-size: 25rpx;
  background: #fff5f8;
}

.calendar-switch {
  display: inline-flex;
  margin-top: 8rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: #f7ecef;
}

.calendar-option {
  padding: 7rpx 20rpx;
  border-radius: 999rpx;
  color: #9a7a84;
  font-size: 23rpx;
}

.calendar-option-active {
  color: #fff;
  background: #d86f83;
}

.lunar-leap-option {
  display: inline-flex;
  margin-top: 8rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  color: #a17e88;
  font-size: 21rpx;
  background: #fff0f3;
}

.lunar-leap-option-active {
  color: #fff;
  background: #c98294;
}

.cover-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.background-options {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.background-swatch {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-shadow: 0 0 0 2rpx rgba(141, 109, 119, 0.12);
  box-sizing: border-box;
}

.background-swatch-active {
  box-shadow: 0 0 0 3rpx #c98294;
}

.background-check {
  color: rgba(80, 57, 65, 0.68);
  font-size: 24rpx;
  font-weight: 700;
}

.cover-btn {
  min-width: 140rpx;
  height: 54rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 24rpx;
  line-height: 54rpx;
  background: #d86f83;
}

.cover-btn-ghost {
  color: #8d6d77;
  background: #f2e4e8;
}

.cover-btn::after {
  border: 0;
}

.panel-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 18rpx;
}

.panel-btn {
  min-width: 128rpx;
  height: 56rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 24rpx;
  background: #d86f83;
}

.panel-btn.ghost {
  color: #8d6d77;
  background: #f2e4e8;
}

.panel-btn::after {
  border: 0;
}
