page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff8f6;
}

.todo-scroll {
  flex: 1;
  overflow-y: hidden;
}

.todo-page {
  padding: 32rpx 32rpx 56rpx;
}

.page-title {
  color: #2b2024;
  font-size: 40rpx;
  font-weight: 700;
}

.page-subtitle {
  margin-top: 12rpx;
  color: #7c6770;
  font-size: 27rpx;
  line-height: 1.5;
}

.stats-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.stats-item {
  flex: 1;
  min-width: 0;
  padding: 14rpx 10rpx;
  border-radius: 16rpx;
  text-align: center;
  background: #fff0f3;
}

.stats-value {
  color: #e85d75;
  font-size: 32rpx;
  font-weight: 700;
}

.stats-label {
  margin-top: 4rpx;
  color: #8d6d77;
  font-size: 22rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #8d6d77;
  font-size: 24rpx;
  background: #fff0f3;
}

.filter-chip-active {
  color: #ffffff;
  background: #e85d75;
}

.new-todo-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  background: #e85d75;
  box-shadow: 0 10rpx 18rpx rgba(232, 93, 117, 0.22);
}

.new-todo-btn::after {
  border: 0;
}

.empty-box {
  margin-top: 24rpx;
  padding: 34rpx 28rpx;
  border-radius: 20rpx;
  color: #9b7f87;
  font-size: 26rpx;
  text-align: center;
  background: #fff1f4;
}

.todo-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.todo-card-completed {
  background: #fff7f9;
}

.todo-card-overdue {
  border: 1rpx solid #f2c2cc;
  background: #fff5f7;
}

.todo-main-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.avatar-wrap {
  display: flex;
  align-items: center;
  width: 74rpx;
  min-height: 74rpx;
}

.avatar-wrap-couple {
  width: 92rpx;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border: 3rpx solid #fff;
  border-radius: 50%;
  background: #ffecef;
}

.avatar-couple + .avatar-couple {
  margin-left: -16rpx;
}

.todo-info {
  flex: 1;
  min-width: 0;
}

.todo-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.todo-title {
  color: #2b2024;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.todo-card-completed .todo-title,
.todo-card-completed .todo-note,
.todo-card-completed .todo-meta {
  opacity: 0.58;
}

.status-tag {
  flex: 0 0 auto;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 44rpx;
}

.status-tag-pending {
  color: #b06d7a;
  background: #ffeef2;
}

.status-tag-done {
  color: #ffffff;
  background: #d6a2af;
}

.status-tag-overdue {
  color: #ffffff;
  background: #e58b9b;
}

.todo-note {
  margin-top: 8rpx;
  color: #634a53;
  font-size: 25rpx;
  line-height: 1.5;
}

.todo-meta {
  margin-top: 10rpx;
  color: #977a84;
  font-size: 23rpx;
}

.todo-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
}

.todo-meta-row .todo-meta {
  margin-top: 0;
}

.due-today-tag {
  flex: 0 0 auto;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: #c56f80;
  font-size: 21rpx;
  background: #ffe9ee;
}

.todo-action-row {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 14rpx;
}

.toggle-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  background: #e85d75;
}

.toggle-btn-done {
  color: #8d6d77;
  background: #f2dfe5;
}

.delete-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #b27a86;
  font-size: 24rpx;
  background: #f7e8ec;
}

.toggle-btn::after,
.clear-due::after,
.panel-btn::after {
  border: 0;
}

.creator-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(43, 32, 36, 0.34);
}

.creator-panel {
  width: 100%;
  padding: 30rpx 30rpx 42rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
}

.panel-title {
  color: #2b2024;
  font-size: 34rpx;
  font-weight: 700;
}

.form-input,
.form-textarea {
  width: 100%;
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  color: #2b2024;
  font-size: 26rpx;
  background: #fff5f8;
  box-sizing: border-box;
}

.form-textarea {
  min-height: 140rpx;
  line-height: 1.5;
}

.target-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.target-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 54rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #8d6d77;
  font-size: 24rpx;
  background: #fff0f3;
}

.target-chip-active {
  color: #ffffff;
  background: #e85d75;
}

.due-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.due-picker {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 260rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #8d6d77;
  font-size: 24rpx;
  background: #fff0f3;
}

.clear-due {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 100rpx;
  height: 54rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #e85d75;
  font-size: 24rpx;
  background: #ffe9ee;
}

.panel-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 20rpx;
}

.panel-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 128rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  background: #e85d75;
}

.panel-btn.ghost {
  color: #8d6d77;
  background: #f2e4e8;
}
