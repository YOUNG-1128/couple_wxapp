<navigation-bar title="输入邀请码" back="{{true}}" color="black" background="#FFFAF8"></navigation-bar>
<view class="bind-page">
  <common-card featured="{{true}}">
    <view class="bind-title">绑定另一半</view>
    <view class="bind-desc">输入 TA 发给你的邀请码，绑定成功后两个人会共用同一个 coupleId。</view>

    <input
      class="bind-input"
      placeholder="请输入 6 位邀请码"
      maxlength="12"
      value="{{inviteCode}}"
      bindinput="onInviteCodeInput"
    />

    <button class="bind-btn" bindtap="onSubmitBind" loading="{{submitting}}">确认绑定</button>
  </common-card>
</view>
