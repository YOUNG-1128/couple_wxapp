.miss-section {
  margin-top: 28rpx;
  padding: 32rpx;
  border: 1rpx solid #efe0e3;
  border-radius: 14rpx;
  background: #fff9f8;
}

.miss-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 176rpx;
  height: 58rpx;
  margin: 0 auto;
  padding: 0 22rpx;
  border: 1rpx solid #e6cbd0;
  border-radius: 10rpx;
  color: #9f5d6c;
  font-size: 24rpx;
  font-weight: 600;
  background: #fff4f5;
}

.miss-button::after {
  border: 0;
}

.miss-text {
  margin-top: 18rpx;
  color: #8b6470;
  font-size: 26rpx;
  line-height: 1.5;
  text-align: center;
}

.miss-button::before {
  content: '';
  width: 15rpx;
  height: 15rpx;
  margin-right: 12rpx;
  border: 3rpx solid currentColor;
  border-top-color: transparent;
  border-left-color: transparent;
  border-radius: 4rpx 8rpx 4rpx 8rpx;
  transform: rotate(45deg);
}
