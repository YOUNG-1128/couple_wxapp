.card-title {
  color: #2b2024;
  font-size: 32rpx;
  font-weight: 700;
}

.status-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.status-box {
  padding: 24rpx;
  border: 1rpx solid #eee1e3;
  border-radius: 12rpx;
  background: #fffdfb;
}

.status-label {
  color: #9a7b84;
  font-size: 24rpx;
}

.status-value {
  margin-top: 10rpx;
  color: #d86f83;
  font-size: 28rpx;
  font-weight: 700;
}

.status-waiting {
  color: #7c6770;
}

.account-desc {
  margin-top: 18rpx;
  color: #9a7b84;
  font-size: 25rpx;
  line-height: 1.5;
}
