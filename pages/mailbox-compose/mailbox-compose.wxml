<navigation-bar title="写信" back="{{true}}" color="black" background="#FFFAF8"></navigation-bar>
<scroll-view class="compose-scroll" type="list" scroll-y>
  <view class="compose-page">
    <view class="letter-paper">
      <input class="paper-title-input" placeholder="写一个标题，也可以留空" maxlength="60" value="{{title}}" bindinput="onTitleInput" />
      <input class="paper-greeting-input" placeholder="怎么称呼收信的人？" maxlength="60" value="{{greeting}}" bindinput="onGreetingInput" />
      <textarea
        class="paper-content-input"
        placeholder="在这里写下想说的话……"
        value="{{content}}"
        maxlength="2000"
        bindinput="onContentInput"
      ></textarea>

      <view class="paper-image-grid" wx:if="{{images.length}}">
        <view class="image-item" wx:for="{{images}}" wx:key="*this">
          <image class="picked-image" src="{{item}}" mode="aspectFill" data-src="{{item}}" bindtap="onPreviewImage"></image>
          <view class="remove-image" data-index="{{index}}" bindtap="onRemoveImage"><view class="ui-icon ui-icon-close"></view></view>
        </view>
      </view>

      <view class="paper-footer">
        <input class="paper-sign-input" placeholder="写下你的落款" maxlength="60" value="{{signature}}" bindinput="onSignatureInput" />
        <input class="paper-date-input" placeholder="写下日期或特别的时刻" maxlength="80" value="{{letterDateText}}" bindinput="onLetterDateInput" />
      </view>
    </view>

    <view class="delivery-panel">
      <view class="delivery-label">选择送达方式，最后点击下方寄出按钮</view>
      <view class="send-mode-row">
        <view class="delivery-mode {{sendMode === 'now' ? 'delivery-mode-active' : ''}}" data-mode="now" bindtap="onSelectSendMode">立即送达</view>
        <view class="delivery-mode {{sendMode === 'scheduled' ? 'delivery-mode-active' : ''}}" data-mode="scheduled" bindtap="onSelectSendMode">约定时间</view>
      </view>

      <view class="schedule-row" wx:if="{{sendMode === 'scheduled'}}">
        <picker mode="date" value="{{scheduleDate}}" bindchange="onScheduleDateChange">
          <view class="picker-cell">{{scheduleDate || '选择日期'}}</view>
        </picker>
        <picker mode="time" value="{{scheduleTime}}" bindchange="onScheduleTimeChange">
          <view class="picker-cell">{{scheduleTime || '选择时间'}}</view>
        </picker>
      </view>

      <view class="compose-action-row">
        <button class="paper-tool-btn" bindtap="onChooseImages"><view class="paperclip-icon"></view>添加照片</button>
        <button class="paper-tool-btn" bindtap="onSaveDraft"><view class="draft-paper-icon"></view>保存草稿</button>
        <button class="letter-send-btn" bindtap="onSend" loading="{{sending}}"><view class="send-letter-icon"></view>{{sendMode === 'scheduled' ? '按约定寄出' : '寄出这封信'}}</button>
      </view>
    </view>
  </view>
</scroll-view>
