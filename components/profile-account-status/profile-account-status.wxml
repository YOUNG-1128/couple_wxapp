<common-card>
  <view class="card-title">账号绑定状态</view>
  <view class="status-grid">
    <view class="status-box">
      <view class="status-label">我</view>
      <view class="status-value">{{account.self}}</view>
    </view>
    <view class="status-box">
      <view class="status-label">对方</view>
      <view class="status-value status-waiting">{{account.partner}}</view>
    </view>
  </view>
  <view class="account-desc">{{account.desc}}</view>
</common-card>
