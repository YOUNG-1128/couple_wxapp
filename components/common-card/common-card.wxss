.common-card {
  margin-top: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #efe3e5;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.82);
}

.common-card-featured {
  margin-top: 0;
  padding: 32rpx;
  border-color: #eedcdf;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #fffdfb 0%, #fff7f6 100%);
  box-shadow: none;
}
