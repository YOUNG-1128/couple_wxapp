<navigation-bar title="功能" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="function-scroll" type="list" scroll-y>
  <view class="function-page">
    <common-card featured="{{true}}">
      <view class="page-title">功能中心</view>
      <view class="page-subtitle">把常用功能都放在一个地方，找起来更轻松。</view>
    </common-card>

    <view class="feature-grid">
      <view class="feature-item" wx:for="{{features}}" wx:key="key" data-target="{{item.target}}" bindtap="onFeatureTap">
        <view class="feature-icon">{{item.icon}}</view>
        <view class="feature-name">{{item.name}}</view>
        <view class="feature-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>
</scroll-view>
