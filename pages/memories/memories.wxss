page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff7f8;
}

.scroll-area {
  flex: 1;
  overflow-y: hidden;
}

.page-content {
  padding: 32rpx;
}

.hero {
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.hero-title {
  color: #2b2024;
  font-size: 44rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 16rpx;
  color: #7a6870;
  font-size: 28rpx;
  line-height: 1.6;
}
