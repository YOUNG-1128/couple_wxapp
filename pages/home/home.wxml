<navigation-bar back="{{false}}" color="black" background="#FFFAF8"></navigation-bar>
<scroll-view class="home-scroll" type="list" scroll-y>
  <view class="home-page">
    <view class="hero-card" bindlongpress="onReplayOpening">
      <view class="hero-main">
        <view class="hero-badge">{{loveInfo.isConfigured ? '恋爱天数' : (loveInfo.isBound ? '我们的故事' : (loveInfo.hasInvite ? '邀请正在路上' : '属于两个人的小世界'))}}</view>
        <view class="hero-days-row" wx:if="{{loveInfo.isConfigured}}">
          <text class="hero-days">{{loveInfo.days}}</text>
          <text class="hero-days-unit">天</text>
        </view>
        <view class="hero-line">{{loveInfo.isConfigured ? heroLine : (loveInfo.isBound ? '补上故事开始的那一天' : (loveInfo.hasInvite ? '等 TA 沿着轨迹来到你身边' : '等那个特别的人，来到同一个方向'))}}</view>
        <view class="hero-note relationship-entry" bindtap="onOpenRelationshipFlow">
          {{loveInfo.isConfigured ? ('始于 ' + loveInfo.startDate + ' · 轻触可修改') : (loveInfo.isBound ? '轻触设置恋爱开始日' : (loveInfo.hasInvite ? '轻触查看相遇暗号' : '轻触邀请 TA 或加入 TA'))}}
        </view>
      </view>

      <view class="heart-action-row">
        <button class="heart-btn" bindtap="onSendMissYou">
          <view class="ui-icon ui-icon-heart heart-icon"></view>
          <text class="heart-text">想 TA</text>
        </button>
      </view>

      <view class="avatar-row">
        <view class="avatar-group" bindtap="onOpenMyStatusPanel">
          <image class="avatar" src="{{myUser.avatarUrl}}" mode="aspectFill"></image>
          <view class="avatar-name">{{myUser.nickName || '我'}}</view>
          <view class="status-bubble {{hasMyStatus ? 'status-bubble-active' : ''}}">{{myStatusText}}</view>
        </view>

        <view class="avatar-group">
          <image class="avatar" src="{{partnerUser.avatarUrl}}" mode="aspectFill"></image>
          <view class="avatar-name">{{partnerUser.nickName || 'TA'}}</view>
          <view class="status-bubble {{hasPartnerStatus ? 'status-bubble-active' : ''}}">{{partnerStatusText}}</view>
        </view>
      </view>
    </view>

    <common-card>
      <view class="section-title">今天要做的事</view>
      <view wx:if="{{todayTasks.length}}" class="task-list">
        <view class="task-item" wx:for="{{todayTasks}}" wx:key="id">
          <view class="task-main">
            <view class="task-title">{{item.title}}</view>
            <view class="task-subtitle">{{item.subtitle}}</view>
          </view>
          <button class="task-btn" data-target-page="{{item.targetPage}}" data-target-section="{{item.targetSection}}" bindtap="onTaskTap">{{item.actionText || '去处理'}}</button>
        </view>
      </view>
      <view wx:else class="empty-text">今天要做的事已经完成了，去和 TA 说句话吧</view>
    </common-card>

    <common-card wx:if="{{monthAnniversaries.length}}" bindtap="onAnniversaryTap">
      <view class="section-title">接下来值得期待的日子</view>
      <view class="anniversary-list">
        <view class="anniversary-item" wx:for="{{monthAnniversaries}}" wx:key="title">
          <view class="item-title">{{item.title}}</view>
          <view class="item-meta">{{item.date}} · 还有 {{item.daysLeft}} 天</view>
        </view>
      </view>
    </common-card>
  </view>
</scroll-view>

<view class="status-panel-mask" wx:if="{{showStatusPanel}}" bindtap="onCloseStatusPanel">
  <view class="status-panel" catchtap="noop">
    <view class="panel-title">设置今天的状态</view>
    <view class="panel-subtitle">仅可设置“我的状态”</view>

    <view class="status-options">
      <view
        class="status-chip {{selectedMyStatus === item.value ? 'status-chip-active' : ''}}"
        wx:for="{{statusOptions}}"
        wx:key="value"
        data-status="{{item.value}}"
        bindtap="onSelectMyStatus"
      >
        {{item.label}}
      </view>
    </view>
  </view>
</view>

<view
  wx:if="{{showOpening}}"
  class="opening opening-{{openingMode}} {{openingReady && !openingInteractive ? 'opening-ready' : 'opening-stay'}}"
>
  <block wx:if="{{openingReady}}">
    <view class="opening-skip" bindtap="onSkipOpening">稍后再说</view>

    <view class="opening-date">{{openingEyebrow}}</view>

    <view class="opening-stage">
      <view class="opening-track opening-track-rose">
        <view class="opening-track-glow"></view>
      </view>
      <view class="opening-track opening-track-gold">
        <view class="opening-track-glow"></view>
      </view>

      <view class="opening-orbit">
        <view class="opening-loop opening-loop-left"></view>
        <view class="opening-loop opening-loop-right"></view>
        <view class="opening-knot"></view>
      </view>

      <view class="opening-point opening-point-rose">
        <image wx:if="{{myUser.avatarUrl && openingMode !== 'solo' && openingMode !== 'inviting'}}" class="opening-point-core opening-avatar" src="{{myUser.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="opening-point-core"></view>
        <view wx:if="{{showOpeningNames}}" class="opening-name">{{openingMyName}}</view>
      </view>
      <view class="opening-point opening-point-gold">
        <image wx:if="{{partnerUser.avatarUrl && openingMode !== 'solo' && openingMode !== 'inviting'}}" class="opening-point-core opening-avatar" src="{{partnerUser.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="opening-point-core"></view>
        <view wx:if="{{showOpeningNames}}" class="opening-name">{{openingPartnerName}}</view>
      </view>

      <view class="opening-pulse opening-pulse-one"></view>
      <view class="opening-pulse opening-pulse-two"></view>
    </view>

    <view class="opening-copy">
      <view class="opening-title">{{openingTitle}}</view>
      <view class="opening-subtitle">{{openingSubtitle}}</view>
    </view>

    <view class="opening-actions" wx:if="{{openingMode === 'solo'}}" catchtap="noop">
      <button class="opening-primary" bindtap="onOpeningInvite" loading="{{openingBusy}}">邀请 TA 来这里</button>
      <button class="opening-secondary" bindtap="onOpeningJoin" disabled="{{openingBusy}}">我收到了邀请</button>
    </view>

    <view class="opening-actions opening-profile" wx:if="{{openingMode === 'profile'}}" catchtap="noop">
      <button class="opening-avatar-picker" bindtap="onOpeningChooseAvatar" loading="{{openingBusy}}">
        <image wx:if="{{openingProfileAvatar}}" class="opening-profile-avatar" src="{{openingProfileAvatar}}" mode="aspectFill"></image>
        <view wx:else class="opening-profile-light"></view>
        <text>{{openingProfileAvatar ? '换一张头像' : '选择头像（可跳过）'}}</text>
      </button>
      <input class="opening-input" placeholder="怎么称呼你？（可跳过）" maxlength="20" value="{{openingProfileNickName}}" bindinput="onOpeningProfileInput" />
      <button class="opening-primary" bindtap="onContinueOpeningProfile" loading="{{openingBusy}}">继续</button>
    </view>

    <view class="opening-actions" wx:if="{{openingMode === 'inviting'}}" catchtap="noop">
      <view class="opening-code-label">把这串相遇暗号告诉 TA</view>
      <view class="opening-code">{{openingInviteCode}}</view>
      <button class="opening-primary" bindtap="onCopyOpeningInvite">复制相遇暗号</button>
      <button class="opening-secondary" open-type="share">分享给 TA</button>
      <button class="opening-secondary" bindtap="onRefreshOpeningBinding" loading="{{openingBusy}}">TA 已加入？刷新看看</button>
      <button class="opening-text-action" bindtap="onEnterHomeWhileWaiting">先进入我们的小世界</button>
    </view>

    <view class="opening-actions" wx:if="{{openingMode === 'joining'}}" catchtap="noop">
      <input class="opening-input opening-code-input" placeholder="输入 6 位相遇暗号" maxlength="12" value="{{openingJoinCode}}" bindinput="onOpeningJoinCodeInput" />
      <button class="opening-primary" bindtap="onSubmitOpeningJoin" loading="{{openingBusy}}">沿着轨迹去见 TA</button>
    </view>

    <view class="opening-actions" wx:if="{{openingMode === 'just-connected'}}" catchtap="noop">
      <button class="opening-primary" bindtap="onContinueConnected">一起记住故事开始的日子</button>
    </view>

    <view class="opening-actions" wx:if="{{openingMode === 'choose-start-date'}}" catchtap="noop">
      <picker mode="date" value="{{relationshipDateDraft}}" end="{{todayKey}}" bindchange="onRelationshipDateChange">
        <view class="opening-date-picker">{{relationshipDateDraft || '选择日期'}}</view>
      </picker>
      <button class="opening-primary" bindtap="onSaveRelationshipDate" loading="{{openingBusy}}">一起记住这一天</button>
    </view>
  </block>
</view>
