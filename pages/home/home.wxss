page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fffaf8;
}

.home-scroll {
  flex: 1;
  overflow-y: hidden;
}

.home-page {
  padding: 12rpx 28rpx 68rpx;
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 32rpx 28rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fff2f4 0%, #fff8ef 100%);
  box-shadow: none;
}

.hero-card::after {
  content: '';
  position: absolute;
  right: -48rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(215, 134, 151, 0.1);
}

.hero-main {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 50rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #9b6f7a;
  font-size: 23rpx;
  background: rgba(255, 255, 255, 0.8);
}

.hero-days-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 18rpx;
}

.hero-days {
  color: #c45e72;
  font-size: 76rpx;
  font-weight: 700;
  line-height: 1;
}

.hero-days-unit {
  color: #8f6a74;
  font-size: 30rpx;
}

.hero-line {
  margin-top: 14rpx;
  color: #5a4048;
  font-size: 30rpx;
  font-weight: 600;
}

.hero-note {
  margin-top: 8rpx;
  color: #9f8088;
  font-size: 24rpx;
}

.relationship-entry {
  position: relative;
  z-index: 2;
  display: inline-flex;
  padding: 8rpx 0;
}

.heart-action-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  margin-top: 22rpx;
}

.heart-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-width: 188rpx;
  height: 70rpx;
  margin: 0;
  padding: 0 26rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #d86f83 0%, #d78697 100%);
  box-shadow: 0 12rpx 24rpx rgba(216, 105, 130, 0.24);
}

.heart-btn::after {
  border: 0;
}

.heart-icon {
  font-size: 28rpx;
  line-height: 1;
}

.heart-text {
  line-height: 1;
}

.avatar-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.avatar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 180rpx;
}

.avatar {
  width: 84rpx;
  height: 84rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #ffecef;
}

.avatar-name {
  margin-top: 8rpx;
  color: #7f626b;
  font-size: 22rpx;
}

.status-bubble {
  margin-top: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #9a7b84;
  font-size: 22rpx;
  line-height: 1.2;
  background: rgba(255, 255, 255, 0.85);
}

.status-bubble-active {
  color: #ffffff;
  background: #d78697;
}

.section-title {
  color: #2b2024;
  font-size: 32rpx;
  font-weight: 700;
}

.task-list,
.anniversary-list {
  margin-top: 16rpx;
}

.task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.task-item + .task-item {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f6e8eb;
}

.task-main {
  flex: 1;
  min-width: 0;
}

.task-title {
  color: #4f3c43;
  font-size: 27rpx;
  line-height: 1.4;
}

.task-subtitle {
  margin-top: 6rpx;
  color: #9a7b84;
  font-size: 23rpx;
  line-height: 1.4;
}

.task-btn {
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 0;
  max-width: 150rpx;
  height: 54rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 10rpx;
  color: #9f5d6c;
  font-size: 23rpx;
  background: #fff9f8;
}

.task-btn::after {
  border: 0;
}

.anniversary-item + .anniversary-item {
  margin-top: 12rpx;
}

.item-title {
  color: #4f3c43;
  font-size: 26rpx;
}

.item-meta {
  margin-top: 5rpx;
  color: #9a7b84;
  font-size: 23rpx;
}

.empty-text {
  margin-top: 14rpx;
  color: #9a7b84;
  font-size: 25rpx;
  line-height: 1.5;
}

.status-panel-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(43, 32, 36, 0.3);
}

.status-panel {
  width: 100%;
  padding: 28rpx 28rpx 40rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
}

.panel-title {
  color: #2b2024;
  font-size: 34rpx;
  font-weight: 700;
}

.panel-subtitle {
  margin-top: 8rpx;
  color: #977a84;
  font-size: 24rpx;
}

.status-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #8d6d77;
  font-size: 24rpx;
  background: #f8edf0;
}

.status-chip-active {
  color: #ffffff;
  background: #d78697;
}

.opening {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: linear-gradient(180deg, #fffdfb 0%, #fff8f8 58%, #fffaf6 100%);
}

.opening::before {
  content: '';
  position: absolute;
  top: 8%;
  left: 50%;
  width: 520rpx;
  height: 520rpx;
  border: 1rpx solid rgba(206, 152, 162, 0.12);
  border-radius: 50%;
  transform: translateX(-50%);
}

.opening-ready {
  animation: opening-exit 500ms ease 3500ms both;
}

.opening-stay {
  animation: none;
}

.opening-skip {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 32rpx);
  right: 32rpx;
  color: #b2989e;
  font-size: 22rpx;
  animation: opening-copy-in 500ms ease 700ms both;
}

.opening-date {
  position: relative;
  min-height: 30rpx;
  color: #b78a94;
  font-size: 20rpx;
  letter-spacing: 0;
  animation: opening-copy-in 650ms ease 250ms both;
}

.opening-stage {
  position: relative;
  width: 100%;
  height: 360rpx;
  margin-top: 22rpx;
}

.opening-track {
  position: absolute;
  top: 178rpx;
  width: 52%;
  height: 3rpx;
  transform-origin: center;
}

.opening-track-rose {
  left: -5%;
  background: linear-gradient(90deg, rgba(213, 101, 123, 0), rgba(213, 101, 123, 0.65));
  transform: rotate(8deg);
  animation: opening-track-rose 1700ms cubic-bezier(0.4, 0, 0.2, 1) 300ms both;
}

.opening-track-gold {
  right: -5%;
  background: linear-gradient(90deg, rgba(211, 165, 111, 0.62), rgba(211, 165, 111, 0));
  transform: rotate(-8deg);
  animation: opening-track-gold 1700ms cubic-bezier(0.4, 0, 0.2, 1) 500ms both;
}

.opening-track-glow {
  width: 100%;
  height: 18rpx;
  margin-top: -8rpx;
  opacity: 0.18;
  background: inherit;
  filter: blur(8rpx);
}

.opening-point {
  position: absolute;
  top: 151rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.opening-point-core {
  width: 50rpx;
  height: 50rpx;
  border: 7rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 50%;
}

.opening-avatar {
  box-sizing: border-box;
}

.opening-point-rose {
  left: 7%;
  animation: opening-point-rose 1900ms cubic-bezier(0.44, 0, 0.2, 1) 250ms both;
}

.opening-point-rose .opening-point-core {
  background: #d96a80;
  box-shadow: 0 0 0 14rpx rgba(217, 106, 128, 0.08), 0 8rpx 32rpx rgba(217, 106, 128, 0.34);
}

.opening-point-gold {
  right: 7%;
  animation: opening-point-gold 1900ms cubic-bezier(0.44, 0, 0.2, 1) 400ms both;
}

.opening-point-gold .opening-point-core {
  background: #d5a466;
  box-shadow: 0 0 0 14rpx rgba(213, 164, 102, 0.08), 0 8rpx 32rpx rgba(213, 164, 102, 0.32);
}

.opening-name {
  max-width: 180rpx;
  margin-top: 20rpx;
  overflow: hidden;
  color: #94777e;
  font-size: 22rpx;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.opening-orbit {
  position: absolute;
  top: 92rpx;
  left: 50%;
  width: 360rpx;
  height: 180rpx;
  opacity: 0;
  transform: translateX(-50%) scale(0.72);
  animation: opening-orbit-in 900ms ease 1780ms both;
}

.opening-loop {
  position: absolute;
  top: 26rpx;
  width: 174rpx;
  height: 118rpx;
  border: 4rpx solid rgba(204, 104, 124, 0.78);
  border-radius: 60%;
}

.opening-loop-left {
  left: 22rpx;
  transform: rotate(28deg);
}

.opening-loop-right {
  right: 22rpx;
  border-color: rgba(208, 158, 100, 0.78);
  transform: rotate(-28deg);
}

.opening-knot {
  position: absolute;
  top: 76rpx;
  left: 50%;
  width: 18rpx;
  height: 18rpx;
  border: 5rpx solid #fffdfb;
  border-radius: 50%;
  background: #d78886;
  box-shadow: 0 0 0 12rpx rgba(215, 136, 134, 0.12), 0 0 32rpx rgba(215, 136, 134, 0.34);
  transform: translateX(-50%);
}

.opening-pulse {
  position: absolute;
  top: 158rpx;
  left: 50%;
  width: 42rpx;
  height: 42rpx;
  border: 2rpx solid rgba(215, 136, 134, 0.3);
  border-radius: 50%;
  opacity: 0;
  transform: translateX(-50%);
}

.opening-pulse-one {
  animation: opening-pulse 1200ms ease-out 1900ms both;
}

.opening-pulse-two {
  animation: opening-pulse 1200ms ease-out 2250ms both;
}

.opening-copy {
  position: relative;
  width: 100%;
  min-height: 158rpx;
  padding: 0 52rpx;
  text-align: center;
}

.opening-title {
  color: #503d43;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.5;
  animation: opening-copy-in 650ms ease 2180ms both;
}

.opening-subtitle {
  margin-top: 14rpx;
  color: #a0868d;
  font-size: 24rpx;
  line-height: 1.5;
  animation: opening-copy-in 650ms ease 2380ms both;
}

.opening-actions {
  position: relative;
  z-index: 3;
  width: 560rpx;
  margin-top: 30rpx;
  text-align: center;
  animation: opening-copy-in 650ms ease 2500ms both;
}

.opening-actions button {
  box-sizing: border-box;
  width: 100%;
  height: 78rpx;
  margin: 0;
  border: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.opening-actions button::after {
  border: 0;
}

.opening-primary {
  color: #ffffff;
  background: linear-gradient(135deg, #d86f83 0%, #d78697 100%);
  box-shadow: 0 14rpx 30rpx rgba(216, 105, 130, 0.22);
}

.opening-secondary {
  margin-top: 16rpx !important;
  color: #9c6b76;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: inset 0 0 0 1rpx rgba(216, 111, 131, 0.24);
}

.opening-actions .opening-text-action {
  height: 64rpx;
  margin-top: 12rpx;
  color: #a0868d;
  font-size: 24rpx;
  background: transparent;
}

.opening-input,
.opening-date-picker {
  box-sizing: border-box;
  width: 100%;
  height: 80rpx;
  margin-bottom: 18rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  color: #594149;
  font-size: 27rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: inset 0 0 0 1rpx rgba(216, 111, 131, 0.18);
}

.opening-date-picker {
  display: flex;
  align-items: center;
  justify-content: center;
}

.opening-avatar-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: auto !important;
  margin-bottom: 18rpx !important;
  padding: 16rpx 0;
  color: #9c6b76;
  background: transparent;
}

.opening-profile-avatar,
.opening-profile-light {
  width: 92rpx;
  height: 92rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 50%;
}

.opening-profile-light {
  background: #d96a80;
  box-shadow: 0 0 0 14rpx rgba(217, 106, 128, 0.08), 0 8rpx 32rpx rgba(217, 106, 128, 0.24);
}

.opening-code-label {
  color: #9d7f87;
  font-size: 23rpx;
}

.opening-code {
  margin: 12rpx 0 22rpx;
  color: #b65f73;
  font-size: 50rpx;
  font-weight: 700;
  letter-spacing: 12rpx;
}

.opening-solo .opening-track-gold,
.opening-inviting .opening-track-gold,
.opening-joining .opening-track-gold,
.opening-profile .opening-track-gold {
  opacity: 0.42;
  animation-name: opening-track-gold-wait;
}

.opening-solo .opening-point-gold,
.opening-inviting .opening-point-gold,
.opening-joining .opening-point-gold,
.opening-profile .opening-point-gold {
  opacity: 0.45;
  animation-name: opening-point-gold-wait;
}

.opening-solo .opening-orbit,
.opening-inviting .opening-orbit,
.opening-joining .opening-orbit,
.opening-profile .opening-orbit {
  width: 170rpx;
  opacity: 1;
  animation-name: opening-open-circle;
}

.opening-solo .opening-loop-left,
.opening-inviting .opening-loop-left,
.opening-joining .opening-loop-left,
.opening-profile .opening-loop-left {
  top: 18rpx;
  left: 12rpx;
  width: 130rpx;
  height: 130rpx;
  border-color: rgba(204, 104, 124, 0.66);
  border-right-color: transparent;
  border-radius: 50%;
  transform: rotate(-28deg);
}

.opening-solo .opening-loop-right,
.opening-solo .opening-knot,
.opening-inviting .opening-loop-right,
.opening-inviting .opening-knot,
.opening-joining .opening-loop-right,
.opening-joining .opening-knot,
.opening-profile .opening-loop-right,
.opening-profile .opening-knot {
  display: none;
}

.opening-solo .opening-pulse,
.opening-inviting .opening-pulse,
.opening-joining .opening-pulse,
.opening-profile .opening-pulse {
  top: 150rpx;
}

@keyframes opening-track-rose {
  from { opacity: 0; transform: rotate(8deg) scaleX(0); }
  to { opacity: 1; transform: rotate(8deg) scaleX(1); }
}

@keyframes opening-track-gold {
  from { opacity: 0; transform: rotate(-8deg) scaleX(0); }
  to { opacity: 1; transform: rotate(-8deg) scaleX(1); }
}

@keyframes opening-track-gold-wait {
  from { opacity: 0; transform: rotate(-8deg) scaleX(0); }
  to { opacity: 0.42; transform: rotate(-8deg) scaleX(0.74); }
}

@keyframes opening-point-rose {
  from { opacity: 0; transform: translate(0, 22rpx) scale(0.72); }
  to { opacity: 1; transform: translate(calc(43vw - 60rpx), 0) scale(0.72); }
}

@keyframes opening-point-gold {
  from { opacity: 0; transform: translate(0, -22rpx) scale(0.72); }
  to { opacity: 1; transform: translate(calc(-43vw + 60rpx), 0) scale(0.72); }
}

@keyframes opening-point-gold-wait {
  from { opacity: 0; transform: translate(0, -22rpx) scale(0.72); }
  to { opacity: 0.45; transform: translate(calc(-25vw + 60rpx), 0) scale(0.64); }
}

@keyframes opening-orbit-in {
  from { opacity: 0; transform: translateX(-50%) scale(0.72); }
  to { opacity: 1; transform: translateX(-50%) scale(1); }
}

@keyframes opening-open-circle {
  from { opacity: 0; transform: translateX(-50%) rotate(-45deg) scale(0.72); }
  to { opacity: 1; transform: translateX(-50%) rotate(0) scale(1); }
}

@keyframes opening-pulse {
  0% { opacity: 0; transform: translateX(-50%) scale(0.35); }
  35% { opacity: 0.7; }
  100% { opacity: 0; transform: translateX(-50%) scale(4.8); }
}

@keyframes opening-copy-in {
  from { opacity: 0; transform: translateY(14rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes opening-exit {
  from { opacity: 1; }
  to { opacity: 0; }
}
