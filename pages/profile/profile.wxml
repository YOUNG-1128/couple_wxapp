<navigation-bar back="{{false}}" color="black" background="#FFFAF8"></navigation-bar>
<scroll-view class="profile-scroll" type="list" scroll-y>
  <view class="profile-page">
    <view class="profile-header">
      <view class="profile-card-title">关于我们</view>
      <view class="profile-card-desc">慢慢把这里变成属于我们的空间</view>
    </view>

    <common-card>
      <view class="connection-head">
        <view>
          <view class="connection-title">我们的连接</view>
          <view class="connection-desc">
            {{bindingState.isBound ? '两个人已经在这里相遇啦' : (bindingState.hasInvite ? '邀请已经出发，等她来这里' : '先建立只属于你们的连接')}}
          </view>
        </view>
        <view class="connection-status {{bindingState.isBound ? 'connection-status-bound' : ''}}">
          {{bindingState.isBound ? '已连接' : (bindingState.hasInvite ? '等待加入' : '未连接')}}
        </view>
      </view>

      <view class="connection-people">
        <view class="connection-person">
          <view class="connection-avatar-edit" bindtap="onChooseAvatar">
            <image class="connection-avatar" src="{{currentUser.avatarUrl}}" mode="aspectFill"></image>
            <view class="connection-edit-mark"></view>
          </view>
          <view class="connection-name connection-name-edit" bindtap="onEditNickName">
            <view class="connection-name-text">{{currentUser.nickName || '设置昵称'}}</view>
            <view class="connection-name-pencil"></view>
          </view>
          <view class="connection-person-state">{{cloudAuth.isCloudLoggedIn ? '已登录' : '等待登录'}}</view>
        </view>

        <view class="connection-thread">
          <view class="connection-thread-line"></view>
          <view class="connection-heart"></view>
        </view>

        <view class="connection-person">
          <image
            class="connection-avatar"
            wx:if="{{bindingState.isBound && bindingState.partnerProfile && bindingState.partnerProfile.avatarUrl}}"
            src="{{bindingState.partnerProfile.avatarUrl}}"
            mode="aspectFill"
          ></image>
          <view class="connection-avatar connection-avatar-empty" wx:else>
            <view class="connection-avatar-heart"></view>
          </view>
          <view class="connection-name">{{bindingState.isBound && bindingState.partnerProfile ? bindingState.partnerProfile.nickName : '她'}}</view>
          <view class="connection-person-state">{{bindingState.isBound ? '已加入' : '等待加入'}}</view>
        </view>
      </view>

      <view class="invite-note" wx:if="{{bindingState.hasInvite && !bindingState.isBound}}">
        <view class="invite-note-copy">
          <view class="invite-note-label">相遇暗号</view>
          <view class="invite-code">{{bindingState.inviteCode}}</view>
        </view>
        <view class="invite-copy" bindtap="onCopyInviteCode">复制</view>
      </view>

      <view class="connection-actions" wx:if="{{!bindingState.isBound}}">
        <button class="connection-primary" wx:if="{{!cloudAuth.isCloudLoggedIn || !cloudAuth.cloudProfileSynced}}" bindtap="onWechatLogin" loading="{{loggingIn}}">
          {{cloudAuth.isCloudLoggedIn ? '重新连接' : '微信登录'}}
        </button>
        <button class="connection-primary" wx:elif="{{!bindingState.hasInvite}}" bindtap="onCreateInviteCode" loading="{{creatingInvite}}">生成相遇暗号</button>
        <button class="connection-primary" wx:else open-type="share">分享邀请</button>
        <view class="connection-text-action" wx:if="{{cloudAuth.isCloudLoggedIn && cloudAuth.cloudProfileSynced}}" bindtap="onOpenBindPage">
          我收到了暗号
          <view class="connection-arrow"></view>
        </view>
      </view>

      <view class="connection-error" wx:if="{{cloudAuth.cloudProfileSyncError || bindingState.syncError}}">
        连接暂时没有成功，请稍后重新尝试
      </view>
    </common-card>

    
    <profile-status-stats list="{{recentStats}}"></profile-status-stats>
    <profile-preferences notes="{{aboutTaNotes}}" bind:edit="onOpenAboutTaEditor"></profile-preferences>
    <profile-privacy-entry privacy="{{privacy}}" bind:privacytap="onPrivacyTap"></profile-privacy-entry>
  </view>
</scroll-view>

<view class="about-editor-mask" wx:if="{{aboutTaEditorVisible}}" bindtap="onCloseAboutTaEditor">
  <view class="about-editor-panel" catchtap="noop">
    <view class="about-editor-head">
      <view>
        <view class="about-editor-title">关于 TA</view>
        <view class="about-editor-desc">每换一行，就会记成一件小事</view>
      </view>
      <view class="about-editor-close" bindtap="onCloseAboutTaEditor">
        <view class="ui-icon ui-icon-close"></view>
      </view>
    </view>
    <textarea
      class="about-editor-input"
      value="{{aboutTaDraft}}"
      maxlength="1200"
      auto-focus
      placeholder="{{aboutTaPlaceholder}}"
      bindinput="onAboutTaInput"
    ></textarea>
    <view class="about-editor-actions">
      <view class="about-editor-count">{{aboutTaDraft.length}} / 1200</view>
      <button class="about-editor-save" bindtap="onSaveAboutTa">保存这些小事</button>
    </view>
  </view>
</view>
