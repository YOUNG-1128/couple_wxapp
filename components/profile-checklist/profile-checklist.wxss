.card-title {
  color: #2b2024;
  font-size: 32rpx;
  font-weight: 700;
}

.progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.progress-text {
  color: #4f3c43;
  font-size: 28rpx;
  font-weight: 600;
}

.progress-percent {
  color: #d86f83;
  font-size: 26rpx;
  font-weight: 700;
}

.progress-track {
  height: 14rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: #f7eef1;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #d86f83;
}

.task-list {
  margin-top: 24rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
}

.check {
  flex: 0 0 auto;
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid #f0c6cf;
  border-radius: 50%;
}

.check-done {
  border-color: #d86f83;
  background: #d86f83;
}

.task-text {
  margin-left: 16rpx;
  color: #4f3c43;
  font-size: 27rpx;
  line-height: 1.45;
}

.task-done {
  color: #9a7b84;
}
