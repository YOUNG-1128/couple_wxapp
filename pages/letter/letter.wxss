page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: rgba(239, 226, 205, 0.35);
}

.letter-scroll {
  flex: 1;
  overflow-y: hidden;
}

.letter-page {
  min-height: calc(100vh - 96rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 38rpx 32rpx 56rpx;
  box-sizing: border-box;
  background: transparent;
}

.paper-card {
  position: relative;
  overflow: hidden;
  width: 100%;
  padding: 42rpx 36rpx;
  border-radius: 24rpx;
  background: #fff4dc;
  box-shadow:
    0 18rpx 36rpx rgba(99, 74, 45, 0.16),
    0 4rpx 10rpx rgba(99, 74, 45, 0.08);
  box-sizing: border-box;
  transform: scale(0.82);
  opacity: 0;
  transition: transform 280ms ease-out, opacity 280ms ease-out;
}

.paper-card-ready {
  transform: scale(1);
  opacity: 1;
}

.paper-lines {
  pointer-events: none;
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    to bottom,
    rgba(166, 131, 92, 0.03) 0rpx,
    rgba(166, 131, 92, 0.03) 1rpx,
    rgba(255, 255, 255, 0) 1rpx,
    rgba(255, 255, 255, 0) 46rpx
  );
}

.paper-title {
  position: relative;
  z-index: 1;
  color: #4d3a28;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.4;
  word-break: break-all;
  font-family: 'KaiTi', 'Kaiti SC', 'STKaiti', 'FangSong', cursive;
}

.paper-content {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  color: #5d4630;
  font-size: 30rpx;
  line-height: 1.9;
  white-space: pre-wrap;
  word-break: break-all;
  font-family: 'KaiTi', 'Kaiti SC', 'STKaiti', 'FangSong', cursive;
}

.paper-images {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.paper-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 14rpx;
  background: #ffecef;
}

.paper-sign {
  position: relative;
  z-index: 1;
  margin-top: 32rpx;
  color: #7e6240;
  font-size: 27rpx;
  text-align: right;
  font-family: 'KaiTi', 'Kaiti SC', 'STKaiti', 'FangSong', cursive;
}

.paper-date {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  color: #b39a7c;
  font-size: 23rpx;
  text-align: right;
  font-family: 'KaiTi', 'Kaiti SC', 'STKaiti', 'FangSong', cursive;
}
