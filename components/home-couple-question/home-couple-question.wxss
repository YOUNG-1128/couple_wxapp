.card-title {
  color: #2b2024;
  font-size: 32rpx;
  font-weight: 700;
}

.question {
  margin-top: 22rpx;
  color: #4f3c43;
  font-size: 30rpx;
  line-height: 1.55;
}

.hint {
  margin-top: 18rpx;
  color: #9a7b84;
  font-size: 26rpx;
  line-height: 1.5;
}

.answer-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 128rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  color: #4f3c43;
  font-size: 28rpx;
  line-height: 1.5;
  background: #fffaf8;
}

.answer-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 176rpx;
  height: 56rpx;
  margin: 20rpx 0 0 auto;
  padding: 0 20rpx;
  border: 1rpx solid #e6cbd0;
  border-radius: 10rpx;
  color: #9f5d6c;
  font-size: 23rpx;
  font-weight: 600;
  background: #fff9f8;
}

.answer-button::after {
  border: 0;
}

.answer-box {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #fffaf8;
}

.answer-label {
  color: #9a7b84;
  font-size: 24rpx;
}

.answer-text {
  margin-top: 8rpx;
  color: #4f3c43;
  font-size: 28rpx;
  line-height: 1.5;
}

.match-result {
  margin-top: 20rpx;
  color: #d86f83;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.45;
}

.answer-button::before {
  content: '';
  width: 16rpx;
  height: 9rpx;
  margin-right: 10rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  border-radius: 2rpx;
  transform: rotate(-45deg);
}
