.about-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.card-title {
  color: #2b2024;
  font-size: 30rpx;
  font-weight: 700;
}

.card-desc {
  margin-top: 7rpx;
  color: #a18189;
  font-size: 22rpx;
  line-height: 1.5;
}

.edit-button {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid #ead6da;
  border-radius: 10rpx;
  color: #a96b79;
  background: #fff9f8;
}

.edit-pencil {
  width: 20rpx;
  height: 3rpx;
  border-radius: 3rpx;
  background: currentColor;
  transform: rotate(-42deg);
}

.note-list {
  margin-top: 22rpx;
}

.note-item {
  display: grid;
  grid-template-columns: 42rpx 1fr;
  gap: 12rpx;
  padding: 15rpx 0;
  border-top: 1rpx dashed #f0dce0;
}

.note-item:first-child {
  padding-top: 0;
  border-top: 0;
}

.note-item:last-child {
  padding-bottom: 0;
}

.note-index {
  padding-top: 2rpx;
  color: #d293a0;
  font-size: 20rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.note-text {
  color: #4f3c43;
  font-size: 25rpx;
  line-height: 1.6;
  word-break: break-all;
}

.empty-guide {
  margin-top: 20rpx;
  padding: 18rpx;
  border: 1rpx dashed #ead6da;
  border-radius: 10rpx;
  background: #fffaf9;
}

.empty-title {
  color: #8d6d77;
  font-size: 23rpx;
  line-height: 1.5;
}

.guide-line {
  position: relative;
  margin-top: 10rpx;
  padding-left: 24rpx;
  color: #b49aa1;
  font-size: 21rpx;
  line-height: 1.45;
}

.guide-line::before {
  content: '';
  position: absolute;
  top: 12rpx;
  left: 2rpx;
  width: 10rpx;
  border-top: 2rpx solid #deb9c1;
}
