.card-title {
  color: #2b2024;
  font-size: 32rpx;
  font-weight: 700;
}

.comfort-desc {
  margin-top: 12rpx;
  color: #9a7b84;
  font-size: 26rpx;
  line-height: 1.5;
}

.mode-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.mode-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 56rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid #eadde0;
  border-radius: 10rpx;
  color: #8d6d77;
  font-size: 23rpx;
  background: #fffdfb;
}

.mode-button::after {
  border: 0;
}
