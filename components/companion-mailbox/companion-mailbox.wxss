.card-title {
  color: #2b2024;
  font-size: 32rpx;
  font-weight: 700;
}

.mood-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 160rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  color: #4f3c43;
  font-size: 28rpx;
  line-height: 1.5;
  background: #fffaf8;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.mood-tag {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  color: #8b6470;
  font-size: 25rpx;
  background: #ffecef;
}

.mood-tag-active {
  color: #ffffff;
  background: #d86f83;
}

.submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 176rpx;
  height: 56rpx;
  margin: 26rpx 0 0 auto;
  padding: 0 20rpx;
  border: 1rpx solid #e6cbd0;
  border-radius: 10rpx;
  color: #9f5d6c;
  font-size: 23rpx;
  font-weight: 600;
  background: #fff9f8;
}

.submit-button::after {
  border: 0;
}

.submit-button::before {
  content: '';
  width: 16rpx;
  height: 9rpx;
  margin-right: 10rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  border-radius: 2rpx;
  transform: rotate(-45deg);
}
