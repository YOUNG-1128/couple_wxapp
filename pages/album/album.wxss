page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff8f6;
}

.moments-scroll {
  flex: 1;
  overflow-y: hidden;
}

.moments-page {
  padding: 32rpx 32rpx 56rpx;
}

.page-title {
  color: #2b2024;
  font-size: 40rpx;
  font-weight: 700;
}

.page-desc {
  margin-top: 14rpx;
  color: #7c6770;
  font-size: 28rpx;
  line-height: 1.55;
}

.search-entry-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.moments-slogan {
  color: #8d6d77;
  font-size: 25rpx;
}

.entry-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.entry-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  width: 60rpx;
  border-radius: 50%;
  font-size: 30rpx;
  background: #fff4f6;
  box-shadow: 0 4rpx 10rpx rgba(232, 93, 117, 0.08);
}

.search-entry-active {
  background: #ffe9ee;
}

.compose-entry {
  width: 66rpx;
  height: 66rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  background: #e85d75;
  box-shadow: 0 8rpx 18rpx rgba(232, 93, 117, 0.26);
}

.search-active-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #e85d75;
}

.entry-red-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid #fff;
  border-radius: 50%;
  background: #ff4d4f;
}

.clear-filter-entry {
  color: #b05f70;
  font-size: 28rpx;
  background: #ffe9ee;
}

.search-box {
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #fff4f6;
}

.search-label {
  margin-top: 10rpx;
  color: #8d6d77;
  font-size: 24rpx;
}

.author-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 54rpx;
  margin-top: 12rpx;
  margin-right: 12rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #8d6d77;
  font-size: 24rpx;
  background: #ffffff;
}

.author-chip-active {
  color: #ffffff;
  background: #e85d75;
}

.search-input {
  height: 68rpx;
  margin-top: 10rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  color: #2b2024;
  font-size: 26rpx;
  background: #ffffff;
}

.date-filter-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.date-trigger {
  display: inline-flex;
  align-items: center;
  min-width: 280rpx;
  height: 54rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #8d6d77;
  font-size: 24rpx;
  background: #ffffff;
}

.date-option {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 130rpx;
  height: 52rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  color: #8d6d77;
  font-size: 23rpx;
  background: #ffffff;
}

.date-option-active {
  color: #ffffff;
  background: #e85d75;
}

.clear-date {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 100rpx;
  height: 54rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #e85d75;
  font-size: 24rpx;
  background: #ffe9ee;
}

.clear-date::after {
  border: 0;
}

.search-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 16rpx;
}

.small-action {
  min-width: 140rpx;
  height: 56rpx;
  font-size: 24rpx;
}

.composer-head,
.post-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.author-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ffecef;
}

.author-name {
  color: #2b2024;
  font-size: 28rpx;
  font-weight: 700;
}

.composer-textarea {
  width: 100%;
  min-height: 170rpx;
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  color: #2b2024;
  font-size: 28rpx;
  line-height: 1.6;
  background: #fff8fa;
  box-sizing: border-box;
}

.compose-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.compose-image-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
}

.compose-image {
  width: 100%;
  height: 100%;
  border-radius: 14rpx;
  background: #ffecef;
}

.remove-image {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 22rpx;
  background: rgba(43, 32, 36, 0.58);
}

.composer-actions {
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  margin-top: 22rpx;
}

.action-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 164rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 26rpx;
  background: #e85d75;
}

.action-button::after,
.comment-submit::after {
  border: 0;
}

.action-button.ghost {
  color: #8d6d77;
  background: #f9edf0;
}

.empty-box {
  margin-top: 24rpx;
  padding: 34rpx 28rpx;
  border-radius: 20rpx;
  color: #9b7f87;
  font-size: 26rpx;
  text-align: center;
  background: #fff1f4;
}

.post-card {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.post-head-right {
  min-width: 0;
}

.post-time {
  margin-top: 6rpx;
  color: #9a7b84;
  font-size: 23rpx;
}

.post-content {
  margin-top: 16rpx;
  color: #4f3c43;
  font-size: 28rpx;
  line-height: 1.6;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
  max-width: 520rpx;
}

.post-image-item {
  overflow: hidden;
  border-radius: 14rpx;
}

.post-image-count-1 {
  width: 68%;
  min-width: 260rpx;
  max-width: 520rpx;
}

.post-image-count-2,
.post-image-count-4 {
  width: 248rpx;
  height: 248rpx;
}

.post-image-count-3,
.post-image-count-5,
.post-image-count-6,
.post-image-count-7,
.post-image-count-8,
.post-image-count-9 {
  width: 164rpx;
  height: 164rpx;
}

.post-image {
  display: block;
  width: 100%;
  background: #ffecef;
}

.post-image-item-single .post-image-single {
  width: 100%;
  height: auto;
  max-height: 760rpx;
}

.post-image-item-multi {
  overflow: hidden;
}

.post-image-item-multi .post-image-multi {
  width: 100%;
  height: 100%;
}

.comment-list {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: #fff7f9;
}

.comment-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.comment-item + .comment-item {
  margin-top: 14rpx;
}

.comment-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ffecef;
}

.comment-body {
  min-width: 0;
  flex: 1;
}

.comment-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.comment-user {
  color: #755661;
  font-size: 24rpx;
  font-weight: 600;
}

.comment-time {
  color: #a1878f;
  font-size: 21rpx;
}

.comment-content {
  margin-top: 6rpx;
  color: #5d444d;
  font-size: 25rpx;
  line-height: 1.45;
}

.comment-entry {
  display: flex;
  justify-content: flex-end;
  margin-top: 10rpx;
}

.comment-toggle-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  font-size: 28rpx;
  background: #f9edf0;
}

.comment-editor {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 14rpx;
}

.comment-input {
  flex: 1;
  height: 60rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #2b2024;
  font-size: 25rpx;
  background: #fff3f6;
}

.comment-submit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  height: 60rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  background: #e85d75;
}

.date-inline-panel {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fff9fb;
}

.date-inline-scroll {
  max-height: 360rpx;
}

.date-level-block + .date-level-block {
  margin-top: 16rpx;
}

.date-level-title {
  color: #8d6d77;
  font-size: 23rpx;
}

.date-group-options {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.date-empty {
  padding: 20rpx 0;
  color: #9b7f87;
  font-size: 24rpx;
  text-align: center;
}
