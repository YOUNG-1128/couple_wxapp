page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff8f6;
}

.mailbox-scroll {
  flex: 1;
  overflow-y: hidden;
}

.mailbox-page {
  padding: 24rpx 32rpx 56rpx;
}

.mailbox-entry-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 0 16rpx;
}

.mailbox-slogan {
  color: #8d6d77;
  font-size: 25rpx;
}

.entry-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.entry-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  width: 60rpx;
  border-radius: 50%;
  font-size: 30rpx;
  background: #fff4f6;
  box-shadow: 0 4rpx 10rpx rgba(232, 93, 117, 0.08);
}

.compose-entry {
  width: 66rpx;
  height: 66rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  background: #e85d75;
  box-shadow: 0 8rpx 18rpx rgba(232, 93, 117, 0.26);
}

.entry-red-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid #fff;
  border-radius: 50%;
  background: #ff4d4f;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-placeholder {
  height: 1rpx;
}

.section-title {
  color: #2b2024;
  font-size: 31rpx;
  font-weight: 700;
}

.section-badge {
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 999rpx;
  color: #b85764;
  font-size: 22rpx;
  background: #ffe9ee;
}

.letter-item {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f6e8eb;
}

.letter-item-incoming {
  justify-content: flex-start;
}

.letter-item-outgoing {
  justify-content: flex-end;
}

.letter-item-outgoing .avatar-wrap {
  order: 2;
}

.letter-item-outgoing .letter-main {
  order: 1;
}

.avatar-wrap {
  position: relative;
  flex: 0 0 auto;
}

.letter-avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: #ffecef;
}

.avatar-unread-dot {
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid #fff;
  border-radius: 50%;
  background: #ff4d4f;
}

.letter-main {
  width: 78%;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #fff4f6;
  box-sizing: border-box;
}

.letter-main-incoming {
  border-top-left-radius: 6rpx;
}

.letter-main-outgoing {
  border-top-right-radius: 6rpx;
  align-items: flex-end;
  background: #fff0f3;
}

.letter-main-outgoing .letter-title,
.letter-main-outgoing .letter-subtitle {
  text-align: right;
}

.letter-title {
  color: #4f3c43;
  font-size: 26rpx;
  font-weight: 600;
  word-break: break-all;
}

.letter-title-unread {
  font-weight: 700;
  color: #2f2126;
}

.letter-subtitle {
  color: #9a7b84;
  font-size: 23rpx;
  line-height: 1.4;
  word-break: break-all;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.letter-foot {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  width: 100%;
  margin-top: 4rpx;
}

.letter-time {
  color: #b297a0;
  font-size: 22rpx;
}

.status-icon {
  min-width: 34rpx;
  text-align: center;
  font-size: 21rpx;
}

.status-icon-unread {
  color: #b7adb3;
}

.status-icon-read {
  color: #e38ea3;
}

.status-icon-waiting {
  color: #c3b7bd;
}

.empty-text {
  margin-top: 12rpx;
  color: #9a7b84;
  font-size: 24rpx;
}

.reader-mask {
  position: fixed;
  z-index: 120;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(255, 247, 245, 0.7) 0%, rgba(248, 240, 230, 0.72) 100%);
}

.reader-wrap {
  width: 100%;
  max-height: 100vh;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}

.reader-paper {
  position: relative;
  overflow-y: auto;
  max-height: calc(100vh - 48rpx);
  width: 92%;
  margin: 0 auto;
  min-height: 68vh;
  padding: 56rpx 44rpx 44rpx;
  border-radius: 14rpx 10rpx 18rpx 8rpx / 10rpx 16rpx 12rpx 14rpx;
  border: 1rpx solid #e8dbc1;
  background:
    radial-gradient(circle at 84% 8%, rgba(255, 255, 255, 0.48) 0%, rgba(255, 255, 255, 0) 42%),
    linear-gradient(145deg, #fff8eb 0%, #fef2db 44%, #faedd2 100%);
  box-shadow:
    0 14rpx 30rpx rgba(114, 87, 54, 0.12),
    0 3rpx 8rpx rgba(114, 87, 54, 0.06);
  box-sizing: border-box;
  transform: translateY(24rpx) scale(0.98) rotate(-0.5deg);
  opacity: 0;
  transition: transform 320ms ease-out, opacity 320ms ease-out;
}

.reader-paper-ready {
  transform: translateY(0) scale(1) rotate(-0.5deg);
  opacity: 1;
}

.reader-lines {
  pointer-events: none;
  position: absolute;
  left: 0;
  right: 0;
  top: 44rpx;
  bottom: 0;
  background: repeating-linear-gradient(
    to bottom,
    rgba(181, 152, 115, 0.025) 0rpx,
    rgba(181, 152, 115, 0.025) 1rpx,
    rgba(255, 255, 255, 0) 1rpx,
    rgba(255, 255, 255, 0) 52rpx
  );
}

.reader-paper-corner {
  position: absolute;
  top: 0;
  right: 0;
  width: 78rpx;
  height: 78rpx;
  background: linear-gradient(135deg, transparent 0 52%, #ebddc2 52% 100%);
  box-shadow: -4rpx 5rpx 8rpx rgba(118, 88, 53, 0.1);
  z-index: 3;
}

.reader-paper-corner-inner {
  position: absolute;
  top: 0;
  right: 0;
  width: 70rpx;
  height: 70rpx;
  background: linear-gradient(140deg, transparent 0 50%, #fff9ec 50% 100%);
  z-index: 4;
}

.reader-paper-edge {
  position: absolute;
  z-index: 2;
  pointer-events: none;
}

.reader-paper-edge-top {
  top: -2rpx;
  left: 18rpx;
  right: 42rpx;
  height: 6rpx;
  border-radius: 50% 40% 45% 55%;
  background: rgba(214, 188, 149, 0.26);
}

.reader-paper-edge-bottom {
  bottom: -3rpx;
  left: 26rpx;
  right: 22rpx;
  height: 7rpx;
  border-radius: 55% 45% 52% 48%;
  background: rgba(214, 188, 149, 0.24);
}

.reader-paper-edge-left {
  top: 34rpx;
  bottom: 28rpx;
  left: -2rpx;
  width: 5rpx;
  border-radius: 60% 40% 50% 50%;
  background: rgba(214, 188, 149, 0.2);
}

.reader-paper-edge-right {
  top: 48rpx;
  bottom: 20rpx;
  right: -2rpx;
  width: 5rpx;
  border-radius: 40% 60% 48% 52%;
  background: rgba(214, 188, 149, 0.18);
}

.reader-title,
.reader-content,
.reader-sign,
.reader-date,
.reader-images {
  position: relative;
  z-index: 1;
  font-family: 'KaiTi', 'Kaiti SC', 'STKaiti', 'FangSong', cursive;
}

.reader-title {
  padding-right: 76rpx;
  margin-bottom: 10rpx;
  color: #4b3a2a;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.4;
  letter-spacing: 0.5rpx;
  word-break: break-all;
}

.reader-content {
  margin-top: 30rpx;
  color: #5c4630;
  font-size: 30rpx;
  line-height: 2.08;
  letter-spacing: 0.7rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.reader-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.reader-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 14rpx;
  background: #ffecef;
}

.reader-sign {
  margin-top: 40rpx;
  color: #7d6445;
  font-size: 27rpx;
  text-align: right;
  letter-spacing: 0.6rpx;
}

.reader-sign-note {
  color: #947559;
  font-size: 23rpx;
}

.reader-date {
  margin-top: 8rpx;
  color: rgba(140, 118, 94, 0.72);
  font-size: 23rpx;
  text-align: right;
}

.reader-footer {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-top: 8rpx;
}
